                        "example": "Aceite extra virgen 500ml",
                        "nullable": true
                    },
                    "product_type": {
                        "type": "string",
                        "enum": [
                            "lata",
                            "bolsa",
                            "caja",
                            "botella"
                        ],
                        "example": "botella"
                    },
                    "unit_of_measurement": {
                        "type": "string",
                        "example": "ml"
                    },
                    "net_content": {
                        "type": "number",
                        "format": "float",
